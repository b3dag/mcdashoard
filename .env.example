# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit it.

# ── REQUIRED ──────────────────────────────────────────────

# Random 32+ byte string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me_with_a_long_random_string

# RCON passwords — one per server. The variable name must match
# `rcon.password_env` in servers.json, and the value must match the
# password set in that server's server.properties.
#
# Examples (uncomment and fill in for each server you add manually):
#   RCON_PASSWORD_CREATIVE01=set_me_to_match_server.properties
#   RCON_PASSWORD_SURVIVAL=set_me_to_match_server.properties
#
# Tip: addserver.sh adds these automatically when you create a server.

# ── OPTIONAL (sensible defaults) ──────────────────────────

# Where the backend listens. Keep on 127.0.0.1 — Cloudflare Tunnel
# forwards to it. Never bind to 0.0.0.0.
HOST=127.0.0.1
PORT=8080

# Trust X-Forwarded-* headers (needed because Cloudflare Tunnel
# sits in front and rewrites them).
TRUST_PROXY=true

# Path to the SQLite file. Relative paths resolve to project root.
DB_PATH=./data/dashboard.db

# Cookie max age in milliseconds (default: 7 days)
SESSION_MAX_AGE=604800000
